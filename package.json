{
  "name": "survivor-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cloudflare:build": "next build",
    "cloudflare:dev": "npm run build && wrangler pages dev out",
    "db:migrate": "wrangler d1 migrations apply survivor-arena-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply survivor-arena-db --local",
    "db:ping": "wrangler d1 execute survivor-arena-db --remote --command \"SELECT 1 AS ok;\" --json",
    "db:ping:local": "wrangler d1 execute survivor-arena-db --local --command \"SELECT 1 AS ok;\" --json",
    "lint": "eslint",
    "test:flows": "node scripts/arena-flow-smoke-test.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@cloudflare/workers-types": "4.20260613.1",
    "@types/node": "24.10.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "wrangler": "4.100.0"
  }
}
